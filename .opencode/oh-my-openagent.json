{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "ultrawork": { "variant": "high" }
    },
    "prometheus": {
      "prompt_append": "Decompose aggressively. Delegate to deep & quick agents in parallel whenever the task splits. Never implement directly."
    },
    "oracle": {
      "variant": "high"
    },
    "explore": {
      "permission": { "edit": "deny", "bash": "ask" }
    }
  },
  "categories": {
    "unspecified-high":  { "variant": "high" },
    "visual-engineering": {
      "prompt_append": "Frontend/UI focus. Touch only files for the assigned task. Terse output, no preamble."
    }
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 3,
    "tmux_visualization": true
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "tmux": { "enabled": true }
}
