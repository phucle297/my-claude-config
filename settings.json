{
  "model": "opusplan",
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.minimax.io/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "<MINIMAX_API_KEY>",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_MODEL": "MiniMax-M3",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "MiniMax-M3",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M3",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "minimax-m2.5-lightning",
    "ANTHROPIC_SMALL_FAST_MODEL": "minimax-m2.5-lightning",
    "CLAUDE_CODE_SUBAGENT_MODEL": "MiniMax-M3",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/scripts/session-start.sh\" 2>/dev/null || true",
            "timeout": 10,
            "async": true,
            "statusMessage": "Reloading checkpoint..."
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/agent_mail_register.sh\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/mempalace-prompt-hook.js",
            "timeout": 3,
            "statusMessage": "Loading memory..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/scripts/guard-claim.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$HOME/.local/share/mcp_agent_mail\" && uv run python -m mcp_agent_mail.cli file_reservations soon \"$PWD\" --minutes 10 2>/dev/null || true",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/scripts/verify-edit.sh\"",
            "timeout": 120,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "SLUG=$(printf '%s' \"$PWD\" | tr '/' '-' | tr -cd 'a-zA-Z0-9-'); REG_TOKEN=$(cat \"/tmp/mcp-regtoken-${SLUG}\" 2>/dev/null || echo ''); AGENT_MAIL_PROJECT=\"$PWD\" AGENT_MAIL_AGENT='RedPond' AGENT_MAIL_URL='http://127.0.0.1:8765/api/' AGENT_MAIL_TOKEN='aabebf4faba1f9f9bedf133a0cb1ff71d1a8d406903a7881951336beb798b8a6' AGENT_MAIL_REGISTRATION_TOKEN=\"$REG_TOKEN\" AGENT_MAIL_HOOK_FORMAT='json' AGENT_MAIL_INTERVAL='120' \"$HOME/.claude/hooks/check_inbox.sh\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup bash ~/.claude/scripts/session-end.sh > /tmp/claude-session-end.log 2>&1 &",
            "timeout": 5,
            "statusMessage": "Saving session state..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/hooks/caveman-statusline.sh\""
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "gastownhall/beads"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "effortLevel": "high"
}
