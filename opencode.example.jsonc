// =============================================================================
// opencode config EXAMPLE — copy needed blocks into opencode.json
// (opencode.json = strict JSON, no comments. Edit there, not this file.)
//
// Model ID format ALWAYS: "provider/model-id"
// List available:  opencode models
// List authed providers:  opencode auth list
// =============================================================================
{
  "$schema": "https://opencode.ai/config.json",

  // --- Default model (top-level) -------------------------------------------
  // Every agent without its own "model" inherits this.
  // small_model = cheap tasks (title gen, summaries).
  "model": "minimax-coding-plan/MiniMax-M2.7",
  "small_model": "minimax-coding-plan/MiniMax-M2.7",

  // Other minimax tiers available now (minimax-coding-plan provider authed):
  //   minimax-coding-plan/MiniMax-M2.7-highspeed
  //   minimax-coding-plan/MiniMax-M2.5
  //   minimax-coding-plan/MiniMax-M2.5-highspeed
  //   minimax-coding-plan/MiniMax-M3
  //
  // After `opencode auth login` -> Anthropic, these resolve too:
  //   "model": "anthropic/claude-opus-4-8",
  //   "small_model": "anthropic/claude-haiku-4-5",

  "permission": "allow",

  "plugin": [
    "oh-my-openagent",
    "./.opencode/plugins/workflow-hooks"
  ],

  // --- Custom provider (FUTURE) --------------------------------------------
  // Any OpenAI-compatible API (cloud, local Ollama/LM Studio, self-host).
  // Uncomment, fill baseURL/apiKey/models, then ref as "myprovider/model-id".
  //
  // "provider": {
  //   "myprovider": {
  //     "npm": "@ai-sdk/openai-compatible",   // for /v1/chat/completions
  //     "name": "My Provider",
  //     "options": {
  //       "baseURL": "https://api.myprovider.com/v1",
  //       "apiKey": "{env:MY_API_KEY}",        // never hardcode secret
  //       "headers": { "Custom-Header": "value" }
  //     },
  //     "models": {
  //       "my-model-id": {
  //         "name": "My Model",
  //         "limit": { "context": 200000, "output": 65536 }
  //       }
  //     }
  //   }
  // },
  //
  // Local example (Ollama): baseURL "http://localhost:11434/v1"

  // --- Per-agent model override (FUTURE) -----------------------------------
  // Overrides top-level "model" for that agent only.
  // NOTE: oh-my-openagent agents are configured in
  //   ~/.config/opencode/oh-my-openagent.json  (their "model" key wins).
  // This "agent" block is for plain opencode agents in .opencode/agent/.
  //
  // "agent": {
  //   "reviewer": { "model": "minimax-coding-plan/MiniMax-M2.5" },
  //   "planner":  { "model": "minimax-coding-plan/MiniMax-M2.7" }
  // },

  "mcp": {
    "mempalace": {
      "type": "local",
      "command": ["mempalace-mcp", "--palace", "{env:HOME}/.mempalace/{env:OPENCODE_PROJECT_SLUG}"],
      "enabled": true
    },
    "mcp-agent-mail": {
      "type": "remote",
      "url": "http://127.0.0.1:8765/api/",
      "headers": {
        "Authorization": "Bearer {env:AGENT_MAIL_TOKEN}"
      },
      "enabled": true
    }
  }
}
