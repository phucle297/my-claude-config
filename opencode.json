{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-coding-plan/MiniMax-M3",
  "small_model": "minimax-coding-plan/MiniMax-M3",
  "permission": "allow",
  "plugin": [
    "./.opencode/plugins/workflow-hooks",
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp",
        "--palace",
        "{env:HOME}/.mempalace/{env:OPENCODE_PROJECT_SLUG}"
      ],
      "enabled": true
    },
    "mcp-agent-mail": {
      "type": "remote",
      "url": "http://127.0.0.1:8765/api/",
      "headers": {
        "Authorization": "Bearer {env:AGENT_MAIL_TOKEN}"
      },
      "enabled": true
    }
  }
}