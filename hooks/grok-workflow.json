{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.grok/scripts/session-start.sh\" 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|search_replace|write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.grok/scripts/guard-claim.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|search_replace|write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.grok/scripts/verify-edit.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup setsid bash \"$HOME/.grok/scripts/session-end.sh\" </dev/null >> /tmp/grok-session-end.log 2>&1 &",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup setsid bash \"$HOME/.grok/scripts/session-end.sh\" </dev/null >> /tmp/grok-session-end.log 2>&1 &",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
